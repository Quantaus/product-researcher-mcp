# Pick one search provider and set its API key
# Options: tavily, brave, serper
SEARCH_PROVIDER=tavily

# Tavily (1,000 free searches/month) — https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Brave Search (2,000 free searches/month) — https://brave.com/search/api/
BRAVE_API_KEY=BSA-your-key-here

# Serper (2,500 free searches total) — https://serper.dev
SERPER_API_KEY=your-key-here
